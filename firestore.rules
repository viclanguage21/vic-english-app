rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin can read/write anything
    function isAdmin() {
      return request.auth != null && request.auth.uid == "BPj6R6IH5naAcW0SWcZglXL7pEy2";
    }

    match /users/{userId} {

      allow read, write: if isAdmin();

      // Read own document
      allow read: if request.auth != null && request.auth.uid == userId;

      // Create own document on registration (XP must start at 0)
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.xp == 0;

      // Update own document
      allow update: if request.auth != null
        && request.auth.uid == userId
        // Cannot change plan or provider (prevents free→pro self-upgrade)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['plan', 'provider'])
        // XP can only increase, and by at most 1000 per update
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['xp']) ||
          (
            request.resource.data.xp is number &&
            request.resource.data.xp >= resource.data.xp &&
            request.resource.data.xp - resource.data.xp <= 1000
          )
        )
        // completedMissions can only grow (entries cannot be removed), max 500
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['completedMissions']) ||
          (
            request.resource.data.completedMissions is list &&
            request.resource.data.completedMissions.size() <= 500 &&
            request.resource.data.completedMissions.size() >= resource.data.completedMissions.size()
          )
        );

      // No client-side deletes
      allow delete: if false;
    }

    // Non-anonymous authenticated users can read all profiles (leaderboard)
    match /users/{document=**} {
      allow read: if request.auth != null
        && request.auth.token.firebase.sign_in_provider != "anonymous";
    }
  }
}
